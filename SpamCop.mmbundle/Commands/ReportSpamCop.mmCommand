{
	name = "Report Spam to SpamCop";
	uuid = "A1B2C3D4-E5F6-7890-ABCD-EF1234567890";
	keyEquivalent = "@^s";
	input = "raw";
	output = "none";
	executionMode = "singleMessage";
	command = "#!/bin/bash\nMM_RAW_FILE=$(mktemp /tmp/spamcop_raw.XXXXXX)\ncat > \"$MM_RAW_FILE\"\nexport MM_RAW_FILE\n\"${MM_BUNDLE_SUPPORT}/bin/report_spamcop.sh\"\nrm -f \"$MM_RAW_FILE\"";
	environment = {
		MM_SUBJECT  = "${subject}";
	};
}
